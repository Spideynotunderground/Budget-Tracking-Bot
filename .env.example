# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456:ABC-your-token-here

# Groq API key from https://console.groq.com/keys (free)
GROQ_API_KEY=gsk_your_key_here

# Postgres connection string.
# Local docker-compose default:
DATABASE_URL=postgresql://budget:budget@localhost:5432/budget

# Optional overrides
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=llama-3.3-70b-versatile
DEFAULT_CURRENCY=USD
BOT_TIMEZONE=UTC

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow anyone (not recommended for a personal bot).
ALLOWED_USER_IDS=
